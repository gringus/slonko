 from click_repl import ClickCompleter
 from prompt_toolkit.document import Document
 import pytest
 
+_click_major = int(_get_version("click").split(".")[0])
+
 
 @click.group()
 def root_command():
@@ -61,7 +65,7 @@ with pytest.importorskip(
 
 
