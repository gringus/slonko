+[testenv:click82]
+deps =
+    click==8.2.1
+    pytest
+    pytest-cov
+commands = pytest --basetemp={envtmpdir}
+
+[testenv:click83]
+deps =
+    click==8.3.1
+    pytest
+    pytest-cov
+commands = pytest --basetemp={envtmpdir}
