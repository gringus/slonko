prefix=/usr
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include/pdfium

Name: Pdfium
Description: Open-source PDF rendering engine.
Version: @VERSION@

Requires.private: freetype2 harfbuzz harfbuzz-subset icu-uc lcms2 libjpeg libopenjp2 libpng zlib
Cflags: -I${includedir}
Libs: -L${libdir} -lpdfium
